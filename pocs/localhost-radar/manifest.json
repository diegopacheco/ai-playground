{
  "manifest_version": 3,
  "name": "Localhost Radar",
  "version": "1.0.5",
  "description": "Inspect Podman containers, localhost services, and DevTools traffic by Diego Pacheco (diegopacheco.github.io).",
  "minimum_chrome_version": "114",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "tabs"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Open Localhost Radar",
    "default_popup": "src/launcher.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "devtools_page": "src/devtools.html",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
