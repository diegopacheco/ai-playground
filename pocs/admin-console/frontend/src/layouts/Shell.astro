---
import "../styles/global.css";
import CommandPalette from "../navigation/CommandPalette";

interface Props {
  title: string;
  active?: string;
}

const { title, active } = Astro.props;

const links = [
  { href: "/", label: "consoles", key: "consoles" },
  { href: "/projects", label: "projects", key: "projects" },
  { href: "/discovery", label: "discovery", key: "discovery" },
  { href: "/audit-trail", label: "audit", key: "audit" },
  { href: "/users", label: "users", key: "users" },
  { href: "/settings/ai", label: "ai", key: "settings" },
  { href: "/swagger", label: "swagger", key: "swagger" }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Admin Console</title>
  </head>
  <body>
    <div class="app-shell">
      <header class="app-header">
        <span class="app-brand">Admin Console</span>
        <button class="app-command-hint" data-command-hint aria-label="Open the go-to-page palette">
          <span>go to…</span>
          <kbd>⌘K</kbd>
        </button>
        <nav class="app-nav">
          {links.map((link) => (
            <a href={link.href} aria-current={active === link.key ? "page" : undefined}>{link.label}</a>
          ))}
        </nav>
      </header>
      <div class="app-body">
        <slot />
      </div>
      <CommandPalette client:load />
    </div>
    <script>
      document.querySelector("[data-command-hint]")?.addEventListener("click", () => {
        window.dispatchEvent(
          new KeyboardEvent("keydown", { key: "k", metaKey: true, bubbles: true })
        );
      });
    </script>
  </body>
</html>
