{
  "name": "@qa2pw/runner",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "English-to-Playwright generation engine. Drives a real browser via Playwright + a local vision LLM (Ollama + Qwen2.5-VL), emits a flat .spec.ts.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "eval": "bun run eval/runEvals.ts"
  },
  "dependencies": {
    "playwright": "1.55.0"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "@types/bun": "1.3.2"
  },
  "engines": {
    "bun": ">=1.3"
  }
}
