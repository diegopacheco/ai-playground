#!/usr/bin/env python3
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from lib.pipeline import run_pipeline
from lib.detect import detect_target
from lib.storage import update_verdict, run_dir

def usage():
    print("usage: jit {detect|run|verdict|dashboard} ...")
    print("  jit detect [repo]")
    print("  jit run --repo PATH --diff RANGE [--target T] [--workflow W]")
    print("  jit verdict <run_id> <catch_id> {confirmed|expected|deferred}")
    print("  jit dashboard --repo PATH [--port N]")
    print("  jit dashboard --stop")

def main():
    if len(sys.argv) < 2:
        usage()
        sys.exit(2)
    cmd = sys.argv[1]
    args = sys.argv[2:]

    if cmd == "detect":
        repo = Path(args[0] if args else ".").resolve()
        t = detect_target(repo)
        print(t or "none")
        return

    if cmd == "run":
        sys.exit(run_pipeline(args))

    if cmd == "verdict":
        if len(args) != 3:
            usage()
            sys.exit(2)
        run_id, catch_id, verdict = args
        repo = Path(".").resolve()
        update_verdict(run_dir(repo, run_id), catch_id, verdict)
        print(f"verdict set: {catch_id} -> {verdict}")
        return

    if cmd == "dashboard":
        from dashboard.server import serve, stop_server
        if "--stop" in args:
            stop_server()
            return
        serve(args)
        return

    usage()
    sys.exit(2)

if __name__ == "__main__":
    main()
