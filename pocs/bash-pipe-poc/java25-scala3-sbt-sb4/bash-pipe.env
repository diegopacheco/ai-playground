STACK=java25-scala3-sbt-sb4
FRAMEWORK=spring-boot-sbt
PORT=8084
HC_PATH=/actuator/health
JDK_ID=25.0.2-amzn
SBT_OPTS_BP="--batch -Dsbt.color=false -Dsbt.log.noformat=true -Dsbt.server.autostart=false"
BUILD_CMD="sbt $SBT_OPTS_BP compile"
TEST_CMD="sbt $SBT_OPTS_BP test"
RUN_CMD="java -cp \"\$(cat runtime-classpath.txt)\" bp.App"
