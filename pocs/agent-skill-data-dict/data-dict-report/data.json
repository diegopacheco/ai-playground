  "sqlite_ddl": "CREATE TABLE \"appointment\" (\n  \"id\" INTEGER PRIMARY KEY,\n  \"pet_id\" INTEGER,\n  \"staff_name\" TEXT,\n  \"scheduled_at\" TEXT,\n  \"service\" TEXT,\n  \"status\" TEXT,\n  \"notes\" TEXT\n);\nCREATE TABLE \"owner\" (\n  \"id\" INTEGER PRIMARY KEY,\n  \"first_name\" TEXT,\n  \"last_name\" TEXT,\n  \"email\" TEXT,\n  \"phone\" TEXT,\n  \"address\" TEXT,\n  \"created_at\" TEXT DEFAULT CURRENT_TIMESTAMP\n);\nCREATE TABLE \"pet\" (\n  \"id\" INTEGER PRIMARY KEY,\n  \"name\" TEXT,\n  \"species\" TEXT,\n  \"breed\" TEXT,\n  \"birth_date\" TEXT,\n  \"weight_kg\" NUMERIC,\n  \"owner_id\" INTEGER\n);\nCREATE TABLE \"product\" (\n  \"id\" INTEGER PRIMARY KEY,\n  \"sku\" TEXT,\n  \"name\" TEXT,\n  \"category\" TEXT,\n  \"price\" NUMERIC,\n  \"stock_qty\" INTEGER DEFAULT 0,\n  \"supplier_id\" INTEGER\n);\nCREATE TABLE \"supplier\" (\n  \"id\" INTEGER PRIMARY KEY,\n  \"name\" TEXT,\n  \"contact_email\" TEXT,\n  \"phone\" TEXT,\n  \"country\" TEXT DEFAULT 'US',\n  \"active\" INTEGER DEFAULT 'TRUE'\n);\nCREATE TABLE \"vaccination\" (\n  \"id\" INTEGER PRIMARY KEY,\n  \"pet_id\" INTEGER,\n  \"vaccine_name\" TEXT,\n  \"administered_on\" TEXT,\n  \"next_due_on\" TEXT,\n  \"batch_number\" TEXT\n);\nCREATE TABLE \"visit\" (\n  \"id\" INTEGER PRIMARY KEY,\n  \"pet_id\" INTEGER,\n  \"visit_date\" TEXT,\n  \"reason\" TEXT,\n  \"cost\" NUMERIC\n);",
