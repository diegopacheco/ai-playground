FROM rust:1.94-bookworm AS builder
WORKDIR /app
COPY Cargo.toml ./
COPY src ./src
RUN cargo build --release

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y curl nodejs npm ca-certificates && rm -rf /var/lib/apt/lists/* && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then KARCH="arm64"; else KARCH="amd64"; fi && \
    curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/${KARCH}/kubectl" && \
    chmod +x kubectl && mv kubectl /usr/local/bin/ && \
    npm install -g @anthropic-ai/claude-code
COPY --from=builder /app/target/release/k8s-sre-agent-operator /usr/local/bin/sre-agent
EXPOSE 8080
CMD ["sre-agent"]
