{
  "tasks": {
    "build": "deno run -A build.ts",
    "serve": "deno run -A --no-prompt server.ts",
    "start": "deno task build && deno task serve"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["dom", "dom.iterable", "deno.ns", "esnext"]
  },
  "imports": {
    "react": "https://esm.sh/react@18.3.1",
    "react/jsx-runtime": "https://esm.sh/react@18.3.1/jsx-runtime",
    "react-dom/client": "https://esm.sh/react-dom@18.3.1/client",
    "esbuild": "https://deno.land/x/esbuild@v0.24.0/mod.js",
    "esbuild_deno_loader": "jsr:@luca/esbuild-deno-loader@^0.11.0",
    "@std/http/file-server": "jsr:@std/http@1.0.12/file-server",
    "typescript": "npm:typescript@^6.0.0"
  }
}
