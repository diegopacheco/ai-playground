meta {
  name: Update Profile
  type: http
  seq: 2
}

put {
  url: http://localhost:3001/api/users/profile
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "bio": "Full-stack developer who loves snarky humor"
  }
}
